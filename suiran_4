<script>

/* =====================================
   YOKOHAMA SUIRAN HIGH SCHOOL
   PREMIUM JAVASCRIPT
===================================== */

/* フェードイン */

const fadeElements =
document.querySelectorAll('.fade');

const fadeObserver =
new IntersectionObserver(entries=>{

entries.forEach(entry=>{

if(entry.isIntersecting){

entry.target.classList.add('show');

}

});

},{
threshold:0.15
});

fadeElements.forEach(el=>{

fadeObserver.observe(el);

});


/* カウントアップ */

const counters =
document.querySelectorAll('.counter');

const counterObserver =
new IntersectionObserver(entries=>{

entries.forEach(entry=>{

if(entry.isIntersecting){

let counter =
entry.target;

let target =
parseInt(
counter.dataset.target
);

let current = 0;

let increment =
Math.ceil(target / 80);

const timer =
setInterval(()=>{

current += increment;

if(current >= target){

current = target;

clearInterval(timer);

}

counter.innerText =
current;

},20);

counterObserver.unobserve(counter);

}

});

},{
threshold:0.5
});

counters.forEach(counter=>{

counterObserver.observe(counter);

});


/* 3Dカード */

const cards =
document.querySelectorAll('.club');

cards.forEach(card=>{

card.addEventListener(
'mousemove',
e=>{

const rect =
card.getBoundingClientRect();

const x =
e.clientX - rect.left;

const y =
e.clientY - rect.top;

const centerX =
rect.width / 2;

const centerY =
rect.height / 2;

const rotateY =
(x-centerX)/12;

const rotateX =
(centerY-y)/12;

card.style.transform =
`
rotateX(${rotateX}deg)
rotateY(${rotateY}deg)
scale(1.04)
`;

});

card.addEventListener(
'mouseleave',
()=>{

card.style.transform =
'rotateX(0) rotateY(0) scale(1)';

});

});


/* 翠翔祭カウントダウン */

const festivalDate =
new Date(
'2026-09-12'
);

function updateCountdown(){

const now =
new Date();

const diff =
festivalDate - now;

const days =
Math.ceil(
diff /
(1000*60*60*24)
);

const target =
document.getElementById('days');

if(target){

target.innerText =
days > 0
? days
: '開催中';

}

}

updateCountdown();

setInterval(
updateCountdown,
1000
);


/* 卒業生カルーセル */

let alumniIndex = 0;

const alumniTrack =
document.querySelector(
'.alumni-track'
);

setInterval(()=>{

if(!alumniTrack) return;

alumniIndex++;

if(alumniIndex > 2){

alumniIndex = 0;

}

alumniTrack.style.transform =
`translateX(-${alumniIndex*100}%)`;

},5000);


/* NEWSスライダー */

let newsIndex = 0;

const newsTrack =
document.querySelector(
'.news-track'
);

setInterval(()=>{

if(!newsTrack) return;

newsIndex++;

if(newsIndex > 2){

newsIndex = 0;

}

newsTrack.style.transform =
`translateX(-${newsIndex*100}%)`;

},4000);


/* AI受験相談 */

function askAI(){

const input =
document.getElementById(
'question'
);

const log =
document.getElementById(
'chatLog'
);

const q =
input.value.trim();

if(!q) return;

let answer =
'ご質問ありがとうございます。';

if(
q.includes('偏差値')
){

answer =
'学力向上だけでなく探究活動や学校説明会への参加も大切です。';

}

else if(
q.includes('部活')
){

answer =
'翠嵐高校には運動部・文化部ともに多彩な部活動があります。';

}

else if(
q.includes('受験')
){

answer =
'説明会や文化祭に参加して学校の雰囲気を体験してみてください。';

}

else if(
q.includes('探究')
){

answer =
'主体的な課題研究や探究活動を重視しています。';

}

log.innerHTML +=

`<hr>

<p>
<strong>質問:</strong>
${q}
</p>

<p>
<strong>AI:</strong>
${answer}
</p>`;

input.value='';

log.scrollTop =
log.scrollHeight;

}


/* Enterキー送信 */

document
.getElementById('question')
.addEventListener(
'keypress',
function(e){

if(e.key === 'Enter'){

askAI();

}

}
);


/* ヘッダー背景変化 */

window.addEventListener(
'scroll',
()=>{

const header =
document.getElementById(
'header'
);

if(window.scrollY > 100){

header.style.background =
'rgba(15,39,71,.95)';

}else{

header.style.background =
'rgba(15,39,71,.75)';

}

}
);

/* =====================================
ULTRA STAR SKY EFFECT
===================================== */

const starsContainer =
document.createElement('div');

starsContainer.style.position='fixed';
starsContainer.style.top='0';
starsContainer.style.left='0';
starsContainer.style.width='100%';
starsContainer.style.height='100%';
starsContainer.style.pointerEvents='none';
starsContainer.style.zIndex='-1';
starsContainer.style.overflow='hidden';

document.body.appendChild(starsContainer);

/* 星生成 */

for(let i=0;i<300;i++){

const star =
document.createElement('div');

const size =
Math.random()*3+1;

star.style.position='absolute';

star.style.width=size+'px';
star.style.height=size+'px';

star.style.borderRadius='50%';

star.style.background='white';

star.style.left=
Math.random()*100+'%';

star.style.top=
Math.random()*100+'%';

star.style.opacity=
Math.random();

star.style.animation=
`twinkle ${2+Math.random()*4}s infinite`;

starsContainer.appendChild(star);

}

/* 流れ星 */

function createMeteor(){

const meteor =
document.createElement('div');

meteor.style.position='absolute';

meteor.style.width='200px';
meteor.style.height='2px';

meteor.style.background=
'linear-gradient(to right, white, transparent)';

meteor.style.top=
Math.random()*50+'%';

meteor.style.left='-250px';

meteor.style.transform=
'rotate(-25deg)';

meteor.style.opacity='0.9';

meteor.style.animation=
'meteor 2s linear forwards';

starsContainer.appendChild(meteor);

setTimeout(()=>{

meteor.remove();

},2000);

}

setInterval(
createMeteor,
4000
);

/* CSS追加 */

const style =
document.createElement('style');

style.innerHTML = `

@keyframes twinkle{

0%{
opacity:0.2;
transform:scale(1);
}

50%{
opacity:1;
transform:scale(1.8);
}

100%{
opacity:0.2;
transform:scale(1);
}

}

@keyframes meteor{

0%{

transform:
translateX(0)
translateY(0)
rotate(-25deg);

opacity:1;

}

100%{

transform:
translateX(1800px)
translateY(700px)
rotate(-25deg);

opacity:0;

}

}

`;

document.head.appendChild(style);



/* ハンバーガーメニュー */

const menuBtn =
document.getElementById(
'menuBtn'
);

const navMenu =
document.getElementById(
'navMenu'
);

menuBtn.addEventListener(
'click',
()=>{

navMenu.classList.toggle(
'active'
);

}
);


/* 画像モーダル */

const images =
document.querySelectorAll(
'.gallery-image'
);

const modal =
document.getElementById(
'imageModal'
);

const modalImage =
document.getElementById(
'modalImage'
);

const closeModal =
document.getElementById(
'closeModal'
);

if(modal && modalImage && closeModal){

images.forEach(img=>{

img.addEventListener(
'click',
()=>{

modal.style.display='flex';

modalImage.src=
img.src;

});

});

closeModal.addEventListener(
'click',
()=>{

modal.style.display='none';

});

modal.addEventListener(
'click',
()=>{

modal.style.display='none';

});

}

modal.addEventListener(
'click',
()=>{

modal.style.display='none';

});
/* ローディング */

window.addEventListener(
'load',
()=>{

setTimeout(()=>{

const loader =
document.getElementById(
'loader'
);

loader.style.opacity='0';

setTimeout(()=>{

loader.style.display='none';

},1000);

},1000);

});


/* TOP BUTTON */

const topButton =
document.getElementById(
'topButton'
);

window.addEventListener(
'scroll',
()=>{

if(window.scrollY > 400){

topButton.style.display =
'block';

}else{

topButton.style.display =
'none';

}

});

topButton.addEventListener(
'click',
()=>{

window.scrollTo({

top:0,

behavior:'smooth'

});

});

