new Date(
'2026-09-12'
);

function updateCountdown(){

const now =
new Date();

const diff =
festivalDate - now;

const days =
Math.ceil(
diff /
(1000*60*60*24)
);

const target =
document.getElementById('days');

if(target){

target.innerText =
days > 0 ? days : '開催中';

}

}

updateCountdown();

setInterval(
updateCountdown,
1000
);


