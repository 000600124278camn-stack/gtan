let viewer;

function loadScene(scene){

const images={

library:
"images/library360.jpg",

classroom:
"images/classroom360.jpg",

gym:
"images/gym360.jpg"

};

if(viewer){

viewer.destroy();

}

viewer =
pannellum.viewer(
'panorama',
{

type:'equirectangular',

panorama:
images[scene],

autoLoad:true,

showControls:true

});

}

window.addEventListener(
'load',
()=>{

loadScene('library');

});


